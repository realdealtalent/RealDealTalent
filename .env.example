DATABASE_URL=postgres://postgres:postgres@localhost:5432/realdealtalent
ALLOWED_EMAIL=you@example.com
AUTH_SECRET=change-me-to-a-random-64-char-string

# --- Prospecting pipeline ---
# Inngest: get keys from the Inngest dashboard once the app is connected.
# In local dev the Inngest Dev Server runs without these.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Firecrawl — TODO: provision API key before first run.
FIRECRAWL_API_KEY=

# ZoomInfo — username/password auth (JWT).
# TODO: swap to PKI auth (RSA key pair) for production.
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=
